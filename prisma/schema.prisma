generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "admin", "client"]
}

// ============================================================================
// Enums
// ============================================================================

enum MpesaGateway {
  DARAJA
  KCB_BUNI

  @@schema("public")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  WAITING_TO_PACKAGE
  READY_FOR_PICKUP
  PICKED_UP
  FAILED

  @@schema("public")
}

enum MessageType {
  ORDER_UPDATE
  SYSTEM
  PROMOTION
  ALERT

  @@schema("public")
}


enum TestimonialSource {
  facebook
  manual

  @@schema("public")
}

enum ContactStatus {
  new
  read
  archived

  @@schema("public")
}

enum UserRole {
  client
  admin

  @@schema("public")
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT

  @@schema("public")
}

enum PaymentProvider {
  MPESA
  PAYSTACK
  KCB

  @@schema("public")
}

enum MpesaType {
  PAYBILL
  TILL

  @@schema("public")
}

enum DeliveryType {
  PICKUP
  DELIVERY

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED

  @@schema("public")
}

enum TicketStatus {
  OPEN
  RESOLVED
  EXPIRED

  @@schema("public")
}

enum MessageSender {
  CUSTOMER
  ADMIN

  @@schema("public")
}

enum CampaignType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  ALL

  @@schema("admin")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED

  @@schema("admin")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED

  @@schema("admin")
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED

  @@schema("admin")
}

enum InStoreFulfillmentStatus {
  CONFIRMED
  PICKED_UP

  @@schema("admin")
}

enum InStoreProvider {
  MPESA_STK
  MPESA_C2B
  PAYSTACK

  @@schema("admin")
}

enum NotificationSeverity {
  CRITICAL
  WARNING
  INFO

  @@schema("admin")
}

enum NotificationType {
  ORDER_NEW
  ORDER_FAILED
  PAYMENT_ERROR
  PRODUCT_ADDED
  PRODUCT_DELETED
  LOW_STOCK
  STAFF_ADDED
  STAFF_REMOVED
  TICKET_NEW
  TICKET_RESPONSE
  CONTACT_INQUIRY
  DELIVERY_ZONE_REQUEST
  ADMIN_ADDED
  SYSTEM_ALERT

  @@schema("admin")
}

// ============================================================================
// Auth models — Better Auth managed (public schema)
// ============================================================================

model user {
  id               String    @id @default(uuid())
  name             String
  firstName        String?
  lastName         String?
  username         String?   @unique
  phone            String?
  country          String?
  city             String?
  companyId        String?
  email            String    @unique
  emailVerified    Boolean   @default(false)
  image            String?
  role             UserRole  @default(client)
  loginCount       Int       @default(0)
  banned           Boolean   @default(false)
  banReason        String?
  banExpires       DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFaEmail          Boolean   @default(false)
  twoFaPhone          Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)
  usernameChanges      Int       @default(0)
  lastUsernameChange   DateTime?
  passwordChanges      Int       @default(0)
  lastPasswordChange   DateTime?
  phoneCode            String?
  langPreference       String    @default("en-GB")
  currencyDisplay      String    @default("KES")
  notifBotanicalUpdates Boolean  @default(true)
  notifOrderTracking    Boolean  @default(true)
  notifPersonalized     Boolean  @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions         session[]
  accounts         account[]
  cart             cart?
  favorites        favorite[]
  orders           order[]
  adminProfile     adminProfile?
  clientProfile    clientProfile?
  twoFactors       twoFactor[]
  supportTickets   supportTicket[] @relation("TicketOwner")
  assignedTickets  supportTicket[] @relation("TicketAssignee")
  blogPosts        blogPost[]
  loyaltyPoints    loyaltyPoints?
  inboxMessages    inboxMessage[]
  wishlistItems    wishlistItem[]
  blogReactions    blogReaction[]
  blogComments     blogComment[]

  @@index([role])
  @@schema("public")
}

model session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("public")
}

model twoFactor {
  id          String @id
  secret      String
  backupCodes String
  verified    Boolean @default(false)
  userId      String
  user        user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

// ============================================================================
// Storefront models (public schema)
// ============================================================================

model category {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  slug      String      @unique
  imageKey  String
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  products  product[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([isActive, sortOrder])
  @@schema("public")
}

model product {
  id                String         @id @default(uuid())
  name              String
  slug              String         @unique
  /// Nullable because it's Zoho-sourced — a sync with no description for this
  /// item nulls it out rather than leaving stale/default text (see zoho-sync.ts).
  description       String?
  shortDescription  String?
  categoryId        String
  category          category       @relation(fields: [categoryId], references: [id])
  priceKes          Int
  compareAtPriceKes Int?
  variantLabel      String?
  sizes             String[]       @default([])
  howToUse          String?
  ingredients       String?
  bestSeller        Boolean        @default(false)
  isActive          Boolean        @default(true)
  /// DEPRECATED — superseded by branchProductStock (stock is now per-branch).
  /// No longer read by checkout or admin inventory; the public storefront
  /// never gates on stock at all. Left in place for historic data only.
  stock             Int            @default(0)
  /// Manual admin override — the storefront's only stock gate. Independent
  /// of the deprecated `stock` field and per-branch Zoho stock.
  outOfStock        Boolean        @default(false)
  ratingAvg         Float          @default(0)
  ratingCount       Int            @default(0)
  // Zoho catalog fields — populated (or nulled, if absent from Zoho) on every
  // sync. Which Zoho item this maps to per organization now lives in
  // productZohoMapping (each of the two orgs assigns its own opaque item id
  // to "the same" product), not a column here.
  zohoSku             String?
  zohoItemType        String?
  zohoStatus          String?
  zohoUnit            String?
  zohoBrand           String?
  purchaseRateKes     Int?
  /// Raw Zoho category_name text, kept even when it doesn't match one of our
  /// active categories, so the gap is visible for manual reconciliation
  /// instead of silently disappearing (categoryId itself is left untouched).
  zohoCategoryNameRaw String?
  lastZohoSyncedAt    DateTime?
  images            productImage[]
  cartItems         cartItem[]
  favorites         favorite[]
  orderItems        orderItem[]
  branchStocks      branchProductStock[]
  zohoMappings      productZohoMapping[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([categoryId, isActive])
  @@index([isActive, bestSeller])
  @@index([isActive, createdAt])
  @@index([isActive, priceKes])
  @@schema("public")
}

model productImage {
  id        String   @id @default(uuid())
  productId String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  objectKey String
  alt       String   @default("")
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
  @@schema("public")
}

model cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  user      user?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String?    @unique
  items     cartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([updatedAt])
  @@schema("public")
}

model cartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@schema("public")
}

model favorite {
  id        String   @id @default(uuid())
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@schema("public")
}

model testimonial {
  id            String            @id @default(uuid())
  authorName    String
  location      String?
  quote         String
  rating        Int               @default(5)
  title         String?
  orderId       String?
  userId        String?
  beforeKey     String?
  afterKey      String?
  source        TestimonialSource @default(manual)
  approved      Boolean           @default(false)
  sortOrder     Int               @default(0)
  productIds    String[]          @default([])
  contactEmail  String?
  contactPhone  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([approved, sortOrder])
  @@schema("public")
}

model order {
  id           String      @id @default(uuid())
  userId       String?
  user         user?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail   String?
  status       OrderStatus @default(PENDING)
  zohoSoId     String?     @unique
  orderNumber  String?     @unique
  processingBy String?
  processedAt  DateTime?
  confirmedBy  String?
  confirmedAt  DateTime?
  shippedAt    DateTime?
  subtotalKes  Int
  deliveryKes  Int         @default(35000)
  discountKes  Int         @default(0)
  totalKes     Int
  promoCode    String?
  items             orderItem[]
  branchId          String?
  branch            branch?       @relation(fields: [branchId], references: [id])
  transactions      transaction[]
  deliveryAddress   String?
  deliveryCity      String?
  deliveryCounty    String?
  deliveryZone      String?
  deliveryPhone     String?
  deliveryType          DeliveryType  @default(DELIVERY)
  isInternational       Boolean       @default(false)
  paymentStatus         PaymentStatus @default(PENDING)
  receiptSent           Boolean       @default(false)
  pickupCode            String?
  pickupCodeExpiresAt   DateTime?
  pickedUpAt            DateTime?
  customerPickupConfirmedAt DateTime?
  staffPickupConfirmedAt    DateTime?
  reviewedAt            DateTime?
  invoiceNumber         String?       @unique
  invoicePdfKey         String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  statusEvents          orderStatusEvent[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@schema("public")
}

model orderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    product  @relation(fields: [productId], references: [id])
  name       String
  priceKes   Int
  quantity   Int

  @@index([orderId])
  @@schema("public")
}

model branch {
  id                String        @id @default(uuid())
  name              String
  county            String
  address           String?
  phone             String?
  slug              String?
  lat               Float?
  lng               Float?
  mpesaType         MpesaType
  shortcode         String
  invoiceNumber     String?       // KCB Buni invoice/account number (plaintext)
  consumerKeyEnc    String
  consumerSecretEnc String
  passkeyEnc        String?
  mpesaGateway      MpesaGateway  @default(DARAJA)
  paystackSubaccount String?
  cardEligible      Boolean       @default(false)
  apiKeyEnc         String?
  isMain            Boolean       @default(false)
  isActive          Boolean       @default(true)
  // Zoho Inventory — a branch belongs to one of a small number of shared
  // orgs (credentials live on zohoOrganization; several branches can point
  // at the same org). zohoWarehouseId is this branch's Zoho warehouse/
  // location id within that org's catalog, used to split stock per-branch
  // when Zoho's per-warehouse breakdown is available (falls back to the
  // org's aggregate quantity_available when unset — see lib/zoho-sync.ts).
  zohoOrganizationId    String?
  zohoOrganization      zohoOrganization? @relation(fields: [zohoOrganizationId], references: [id])
  zohoWarehouseId       String?
  orders            order[]
  deliveryZones     DeliveryZone[]
  adminProfiles     adminProfile[]
  transactions      transaction[]
  inStoreOrders          inStoreOrder[]
  mpesaC2bTransactions   mpesaC2bTransaction[]
  notifications          notification[]
  branchProductStocks    branchProductStock[]
  zohoPushLogs           zohoPushLog[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([county, isActive])
  @@index([zohoOrganizationId])
  @@schema("public")
}

model DeliveryZone {
  id             String   @id @default(uuid())
  county         String
  name           String
  branchId       String?
  branch         branch?  @relation(fields: [branchId], references: [id])
  deliveryFeeKes Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([county, isActive])
  @@index([branchId])
  @@schema("public")
}

// Per-branch stock count, synced from that branch's own Zoho POS. The
// product catalog itself (name/price/description/images) stays one shared
// row per SKU in `product` — only quantity is branch-specific. Admin/internal
// use only; the public storefront never reads this (deliberately unlimited
// "in stock" on the customer-facing site — see product.stock's deprecation
// note below).
model branchProductStock {
  id           String    @id @default(cuid())
  branchId     String
  branch       branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId    String
  product      product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock        Int       @default(0)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([branchId, productId])
  @@index([productId])
  @@index([branchId, stock])
  @@schema("admin")
}

// One row per real-world Zoho Inventory organization. Several branches can
// share the same org (credentials + webhook secret live here once, not
// duplicated per branch) — see branch.zohoOrganizationId.
model zohoOrganization {
  id               String    @id @default(cuid())
  name             String
  zohoOrgId        String    @unique
  clientIdEnc      String
  clientSecretEnc  String
  refreshTokenEnc  String
  webhookSecretEnc String?
  connectedAt      DateTime?
  branches         branch[]
  productMappings  productZohoMapping[]
  pushLogs         zohoPushLog[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@schema("admin")
}

// Maps a shared product catalog row to its Zoho item id *within one org's
// catalog*. Necessary because each org assigns its own opaque item ids —
// the same physical product has a different zohoItemId under Org A than
// under Org B. Both directions are direct unique-index lookups.
model productZohoMapping {
  id             String           @id @default(cuid())
  productId      String
  product        product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  organizationId String
  organization   zohoOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  zohoItemId     String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([productId, organizationId])
  @@unique([organizationId, zohoItemId])
  @@schema("admin")
}

enum ZohoPushKind {
  SALES_ORDER
  INVENTORY_ADJUSTMENT

  @@schema("admin")
}

enum ZohoPushStatus {
  SENT
  FAILED
  SKIPPED

  @@schema("admin")
}

// Durable record of every outbound push to Zoho (a sale or a manual stock
// adjustment), written once after each attempt completes. Exists so a
// failed push is discoverable in the admin panel instead of only ever
// appearing in server logs — see lib/zoho/push-log.ts.
model zohoPushLog {
  id             String            @id @default(cuid())
  kind           ZohoPushKind
  status         ZohoPushStatus
  organizationId String?
  organization   zohoOrganization? @relation(fields: [organizationId], references: [id])
  branchId       String?
  branch         branch?           @relation(fields: [branchId], references: [id])
  productId      String?
  referenceType  String?           // "order" | "inStoreOrder" | "inventoryAdjustment"
  referenceId    String?
  zohoRecordId   String?
  errorMessage   String?
  createdAt      DateTime          @default(now())

  @@index([status, createdAt])
  @@index([referenceType, referenceId])
  @@schema("admin")
}

model transaction {
  id                   String          @id @default(uuid())
  orderId              String
  order                order           @relation(fields: [orderId], references: [id])
  branchId             String?
  branch               branch?         @relation(fields: [branchId], references: [id])
  provider             PaymentProvider
  checkoutRequestId    String?         @unique
  paystackReference    String?         @unique
  amount               Int
  status               TxStatus        @default(PENDING)
  // Which gateway actually handled this M-Pesa payment — null for non-M-Pesa
  // providers. Recorded from the dispatch result, not inferred from
  // branch.mpesaGateway, since a fallback can route a payment through the
  // other gateway than the branch's configured default.
  mpesaGatewayUsed     MpesaGateway?
  rawRequestPayload    Json?
  rawCallbackPayload   Json?
  mpesaReceiptNumber   String?
  failureReason        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([orderId])
  @@index([checkoutRequestId])
  @@index([status, createdAt])
  @@schema("public")
}

model contactMessage {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(new)
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
  @@schema("public")
}

// ============================================================================
// Admin models (admin schema)
// ============================================================================

model adminProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  user        user       @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      branch?    @relation(fields: [branchId], references: [id])
  fullName        String
  permissions     Json       @default("{}")
  department      String?
  role            String     @default("viewer")
  twoFaMethod     String     @default("totp")
  isSuperAdmin    Boolean    @default(false)
  isActive        Boolean    @default(true)
  accessExpiresAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       auditLog[]

  @@index([branchId])
  @@schema("admin")
}

model auditLog {
  id             String       @id @default(uuid())
  adminProfileId String
  adminProfile   adminProfile @relation(fields: [adminProfileId], references: [id])
  action         String
  resource       String
  resourceId     String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())

  @@index([adminProfileId, createdAt])
  @@schema("admin")
}

model systemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@schema("admin")
}

model notification {
  id          String               @id @default(cuid())
  type        NotificationType
  severity    NotificationSeverity
  title       String
  body        String
  link        String?
  branchId    String?
  branch      branch?              @relation(fields: [branchId], references: [id])
  targetRoles String[]             @default([])
  read        Boolean              @default(false)
  createdAt   DateTime             @default(now())

  recipientStates notificationRecipientState[]

  @@index([read, createdAt])
  @@index([branchId, createdAt])
  @@index([severity, createdAt])
  @@schema("admin")
}

model notificationRecipientState {
  id             String       @id @default(cuid())
  notificationId String
  notification   notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  readAt         DateTime?
  pinned         Boolean      @default(false)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@schema("admin")
}

// ============================================================================
// Client models (client schema)
// ============================================================================

model clientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  country     String?
  city        String?
  companyId   String?  @unique
  companyName String?
  loginCount  Int      @default(0)
  source      String?  // null for normal signups, "IN_STORE" for walk-ins created via admin in-store order flow
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("client")
}

// ============================================================================
// Support Tickets (public schema)
// ============================================================================

model supportTicket {
  id              String          @id @default(cuid())
  ticketNumber    String          @unique
  userId          String
  user            user            @relation("TicketOwner", fields: [userId], references: [id])
  assignedAdminId String?
  assignedAdmin   user?           @relation("TicketAssignee", fields: [assignedAdminId], references: [id])
  subject         String
  status          TicketStatus    @default(OPEN)
  lastActivityAt  DateTime        @default(now())
  expiresAt       DateTime
  messages        ticketMessage[]
  createdAt       DateTime        @default(now())

  @@index([status, lastActivityAt])
  @@index([assignedAdminId, status])
  @@schema("public")
}

model ticketMessage {
  id             String        @id @default(cuid())
  ticketId       String
  ticket         supportTicket @relation(fields: [ticketId], references: [id])
  senderType     MessageSender
  content        String        @db.Text
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  attachmentSize Int?
  emailSentAt    DateTime?
  createdAt      DateTime      @default(now())

  @@index([ticketId])
  @@schema("public")
}

// ============================================================================
// Loyalty (public schema)
// ============================================================================

model loyaltyPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      user     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  tier      String   @default("BRONZE")
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model couponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  userId     String
  orderId    String   @unique
  redeemedAt DateTime @default(now())

  // Not unique on [couponId, userId] anymore — promotion.maxUsesPerUser lets a
  // user redeem the same coupon more than once; resolvePromo() in lib/promo.ts
  // enforces the configured limit by counting rows here instead.
  @@index([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@schema("public")
}

// ============================================================================
// Marketing (admin schema)
// ============================================================================

model campaign {
  id                   String         @id @default(cuid())
  name                 String
  type                 CampaignType
  audienceType         String         @default("ALL")
  subject              String?
  heading              String?
  previewText          String?
  content              String?        @db.Text
  audienceCustomerIds  String[]       @default([])
  status               CampaignStatus @default(DRAFT)
  scheduledAt          DateTime?
  sentAt               DateTime?
  sentCount            Int            @default(0)
  lastError            String?        @db.Text
  createdAt            DateTime       @default(now())

  @@schema("admin")
}

enum CampaignChannel {
  EMAIL
  SMS
  PUSH

  @@schema("admin")
}

enum RecipientStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  SPAM
  FAILED
  OPENED
  CLICKED

  @@schema("admin")
}

model campaignRecipient {
  id                String          @id @default(cuid())
  campaignId        String
  userId            String
  channel           CampaignChannel
  status            RecipientStatus @default(QUEUED)
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  createdAt         DateTime        @default(now())

  @@unique([campaignId, userId, channel])
  @@index([providerMessageId])
  @@schema("admin")
}

model promotion {
  id             String    @id @default(cuid())
  name           String
  type           String
  value          Float
  code           String?   @unique
  minOrder       Int?
  maxUses        Int?
  // How many times a single user may reuse this coupon. 0 = unlimited, 1 = default (one use per user).
  maxUsesPerUser Int       @default(1)
  usedCount      Int       @default(0)
  startDate      DateTime?
  endDate        DateTime?
  status         String    @default("active")
  createdAt      DateTime  @default(now())

  @@schema("admin")
}

// ============================================================================
// Content (admin schema)
// ============================================================================

model blogPost {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String?
  content       String?    @db.Text
  featuredImage String?
  category      String?
  tags          String[]
  status        PostStatus @default(DRAFT)
  authorId      String
  author        user       @relation(fields: [authorId], references: [id])
  authorIds     String[]   @default([])
  publishedAt   DateTime?
  seoTitle      String?
  metaDesc      String?
  views         Int        @default(0)
  createdAt     DateTime   @default(now())

  likeCount     Int        @default(0)
  dislikeCount  Int        @default(0)
  commentCount  Int        @default(0)
  isFeatured    Boolean    @default(false)

  viewEvents    blogView[]
  reactions     blogReaction[]
  comments      blogComment[]

  @@schema("admin")
}

model blogView {
  id         String   @id @default(cuid())
  postId     String
  post       blogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String?
  viewerHash String?
  viewedAt   DateTime @default(now())

  @@index([postId, viewedAt])
  @@schema("admin")
}

model blogReaction {
  id        String       @id @default(cuid())
  postId    String
  post      blogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      user         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
  @@schema("admin")
}

enum ReactionType {
  LIKE
  DISLIKE

  @@schema("admin")
}

model blogComment {
  id        String        @id @default(cuid())
  postId    String
  post      blogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      user          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  content   String
  status    CommentStatus @default(VISIBLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId, status])
  @@schema("admin")
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  FLAGGED

  @@schema("admin")
}

model homepageSection {
  id      String  @id @default(cuid())
  type    String
  order   Int
  visible Boolean @default(true)
  config  Json

  @@schema("admin")
}

model banner {
  id        String    @id @default(cuid())
  name      String
  location  String
  imageKey  String
  ctaText   String?
  ctaLink   String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")

  @@schema("admin")
}

model faq {
  id       String @id @default(cuid())
  question String
  answer   String @db.Text
  group    String @default("General")
  order    Int    @default(0)
  status   String @default("published")

  @@schema("admin")
}

// ============================================================================
// Suppliers + Purchase Orders (admin schema)
// ============================================================================

model supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  categories     String[]
  paymentTerms   String?
  notes          String?
  status         String          @default("active")
  purchaseOrders purchaseOrder[]
  createdAt      DateTime        @default(now())

  @@schema("admin")
}

model purchaseOrder {
  id               String    @id @default(cuid())
  poNumber         String    @unique
  supplierId       String
  supplier         supplier  @relation(fields: [supplierId], references: [id])
  status           POStatus  @default(DRAFT)
  expectedDelivery DateTime?
  notes            String?
  items            Json
  totalAmount      Int
  createdAt        DateTime  @default(now())

  @@schema("admin")
}

// ============================================================================
// Loyalty Tiers (admin schema)
// ============================================================================

model loyaltyTier {
  id         String   @id @default(cuid())
  name       String
  minSpend   Int
  multiplier Float    @default(1.0)
  benefits   String[]
  color      String

  @@schema("admin")
}

// ============================================================================
// Account Dashboard models (public schema)
// ============================================================================

model orderStatusEvent {
  id         String      @id @default(cuid())
  orderId    String
  order      order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     OrderStatus
  note       String?
  occurredAt DateTime    @default(now())

  @@index([orderId])
  @@schema("public")
}

model inboxMessage {
  id        String      @id @default(cuid())
  userId    String
  user      user        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MessageType @default(SYSTEM)
  title     String
  body      String
  orderId   String?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([userId, isRead])
  @@schema("public")
}

model wishlistItem {
  id               String   @id @default(cuid())
  userId           String
  user             user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId        String
  productName      String
  productImage     String?
  priceKes         Int
  originalPriceKes Int?
  addedAt          DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@schema("public")
}

// ============================================================================
// In-Store Orders (admin schema) — walk-in orders created by an admin at a
// branch till. Deliberately separate from order/orderItem/transaction, which
// power the customer-facing storefront checkout flow and must not be touched.
// ============================================================================

model inStoreOrder {
  id                 String                    @id @default(cuid())
  orderNumber        String?                   @unique
  branchId           String
  branch             branch                    @relation(fields: [branchId], references: [id])
  createdByAdminId   String
  createdByAdminName String
  customerUserId     String?
  customerName       String?
  customerPhone      String?
  customerEmail      String?
  items              inStoreOrderItem[]
  subtotalKes        Int
  discountKes        Int                       @default(0)
  promoCode          String?
  totalKes           Int
  fulfillmentStatus  InStoreFulfillmentStatus  @default(CONFIRMED)
  paymentStatus      PaymentStatus             @default(PENDING)
  transactions       inStoreTransaction[]
  invoiceNumber      String?                   @unique
  invoicePdfKey      String?
  receiptSentEmail   Boolean                   @default(false)
  receiptSentSms     Boolean                   @default(false)
  pickedUpAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([branchId, createdAt])
  @@index([branchId, fulfillmentStatus])
  @@index([customerUserId])
  @@schema("admin")
}

model inStoreOrderItem {
  id             String       @id @default(cuid())
  inStoreOrderId String
  inStoreOrder   inStoreOrder @relation(fields: [inStoreOrderId], references: [id], onDelete: Cascade)
  productId      String
  name           String
  priceKes       Int
  quantity       Int

  @@index([inStoreOrderId])
  @@schema("admin")
}

model inStoreTransaction {
  id                      String               @id @default(cuid())
  inStoreOrderId          String
  inStoreOrder            inStoreOrder         @relation(fields: [inStoreOrderId], references: [id])
  provider                InStoreProvider
  amount                  Int
  status                  TxStatus             @default(PENDING)
  checkoutRequestId       String?              @unique
  paystackReference       String?              @unique
  mpesaReceiptNumber      String?
  mpesaGatewayUsed        MpesaGateway?
  matchedC2bTransactionId String?              @unique
  matchedC2bTransaction   mpesaC2bTransaction? @relation(fields: [matchedC2bTransactionId], references: [id])
  rawCallbackPayload      Json?
  failureReason           String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([inStoreOrderId])
  @@index([status, createdAt])
  @@schema("admin")
}

// Raw, append-only log of every Safaricom C2B confirmation received on a
// branch till/paybill (whether or not an admin was actively "listening" for
// a match at the time). matchedInStoreTransactionId is a denormalized,
// unenforced pointer maintained by application code when a row is claimed —
// see schema notes in the migration report for why this side has no FK.
model mpesaC2bTransaction {
  id                           String               @id @default(cuid())
  branchId                     String
  branch                       branch               @relation(fields: [branchId], references: [id])
  transId                      String               @unique
  transAmount                  Int
  msisdn                       String
  firstName                    String?
  middleName                   String?
  lastName                     String?
  transactionTime              DateTime
  billRefNumber                String?
  matchedInStoreTransactionId  String?
  inStoreTransaction           inStoreTransaction?
  rawPayload                   Json
  createdAt                    DateTime             @default(now())

  @@index([branchId, transAmount, createdAt])
  @@schema("admin")
}
