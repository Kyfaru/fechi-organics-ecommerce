generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "admin", "client"]
}

// ============================================================================
// Enums
// ============================================================================

enum MpesaGateway {
  DARAJA
  KCB_BUNI

  @@schema("public")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  WAITING_TO_PACKAGE
  READY_FOR_PICKUP
  PICKED_UP

  @@schema("public")
}

enum MessageType {
  ORDER_UPDATE
  SYSTEM
  PROMOTION
  ALERT

  @@schema("public")
}


enum TestimonialSource {
  facebook
  manual

  @@schema("public")
}

enum ContactStatus {
  new
  read
  archived

  @@schema("public")
}

enum UserRole {
  client
  admin

  @@schema("public")
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT

  @@schema("public")
}

enum PaymentProvider {
  MPESA
  PAYSTACK
  KCB

  @@schema("public")
}

enum MpesaType {
  PAYBILL
  TILL

  @@schema("public")
}

enum DeliveryType {
  PICKUP
  DELIVERY

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED

  @@schema("public")
}

enum TicketStatus {
  OPEN
  RESOLVED
  EXPIRED

  @@schema("public")
}

enum MessageSender {
  CUSTOMER
  ADMIN

  @@schema("public")
}

enum CampaignType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  ALL

  @@schema("admin")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED

  @@schema("admin")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED

  @@schema("admin")
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED

  @@schema("admin")
}

// ============================================================================
// Auth models — Better Auth managed (public schema)
// ============================================================================

model user {
  id               String    @id @default(uuid())
  name             String
  firstName        String?
  lastName         String?
  username         String?   @unique
  phone            String?
  country          String?
  city             String?
  companyId        String?
  email            String    @unique
  emailVerified    Boolean   @default(false)
  image            String?
  role             UserRole  @default(client)
  loginCount       Int       @default(0)
  banned           Boolean   @default(false)
  banReason        String?
  banExpires       DateTime?
  twoFactorEnabled    Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)
  usernameChanges      Int       @default(0)
  lastUsernameChange   DateTime?
  phoneCode            String?
  langPreference       String    @default("en-GB")
  currencyDisplay      String    @default("KES")
  notifBotanicalUpdates Boolean  @default(true)
  notifOrderTracking    Boolean  @default(true)
  notifPersonalized     Boolean  @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions         session[]
  accounts         account[]
  cart             cart?
  favorites        favorite[]
  orders           order[]
  adminProfile     adminProfile?
  clientProfile    clientProfile?
  twoFactors       twoFactor[]
  supportTickets   supportTicket[]
  blogPosts        blogPost[]
  loyaltyPoints    loyaltyPoints?
  inboxMessages    inboxMessage[]
  wishlistItems    wishlistItem[]

  @@index([role])
  @@schema("public")
}

model session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("public")
}

model twoFactor {
  id          String @id
  secret      String
  backupCodes String
  verified    Boolean @default(false)
  userId      String
  user        user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

// ============================================================================
// Storefront models (public schema)
// ============================================================================

model category {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  slug      String      @unique
  imageKey  String
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  products  product[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([isActive, sortOrder])
  @@schema("public")
}

model product {
  id                String         @id @default(uuid())
  name              String
  slug              String         @unique
  description       String
  shortDescription  String?
  categoryId        String
  category          category       @relation(fields: [categoryId], references: [id])
  priceKes          Int
  compareAtPriceKes Int?
  variantLabel      String?
  sizes             String[]       @default([])
  howToUse          String?
  ingredients       String?
  bestSeller        Boolean        @default(false)
  isActive          Boolean        @default(true)
  stock             Int            @default(0)
  ratingAvg         Float          @default(0)
  ratingCount       Int            @default(0)
  zohoItemId        String?        @unique
  images            productImage[]
  cartItems         cartItem[]
  favorites         favorite[]
  orderItems        orderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([categoryId, isActive])
  @@index([isActive, bestSeller])
  @@index([isActive, createdAt])
  @@index([isActive, priceKes])
  @@schema("public")
}

model productImage {
  id        String   @id @default(uuid())
  productId String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  objectKey String
  alt       String   @default("")
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
  @@schema("public")
}

model cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  user      user?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String?    @unique
  items     cartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([updatedAt])
  @@schema("public")
}

model cartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@schema("public")
}

model favorite {
  id        String   @id @default(uuid())
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@schema("public")
}

model testimonial {
  id         String            @id @default(uuid())
  authorName String
  location   String?
  quote      String
  rating     Int               @default(5)
  beforeKey  String
  afterKey   String
  source     TestimonialSource @default(manual)
  approved   Boolean           @default(false)
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([approved, sortOrder])
  @@schema("public")
}

model order {
  id           String      @id @default(uuid())
  userId       String?
  user         user?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail   String?
  status       OrderStatus @default(PENDING)
  zohoSoId     String?     @unique
  orderNumber  String?     @unique
  processingBy String?
  processedAt  DateTime?
  confirmedBy  String?
  confirmedAt  DateTime?
  shippedAt    DateTime?
  subtotalKes  Int
  deliveryKes  Int         @default(35000)
  discountKes  Int         @default(0)
  totalKes     Int
  promoCode    String?
  items             orderItem[]
  branchId          String?
  branch            branch?       @relation(fields: [branchId], references: [id])
  transactions      transaction[]
  deliveryAddress   String?
  deliveryCity      String?
  deliveryCounty    String?
  deliveryZone      String?
  deliveryPhone     String?
  deliveryType          DeliveryType  @default(DELIVERY)
  isInternational       Boolean       @default(false)
  paymentStatus         PaymentStatus @default(PENDING)
  receiptSent           Boolean       @default(false)
  pickupCode            String?
  pickupCodeExpiresAt   DateTime?
  pickedUpAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  statusEvents          orderStatusEvent[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@schema("public")
}

model orderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    product  @relation(fields: [productId], references: [id])
  name       String
  priceKes   Int
  quantity   Int

  @@index([orderId])
  @@schema("public")
}

model branch {
  id                String        @id @default(uuid())
  name              String
  county            String
  lat               Float?
  lng               Float?
  mpesaType         MpesaType
  shortcode         String
  invoiceNumber     String?       // KCB Buni invoice/account number (plaintext)
  consumerKeyEnc    String
  consumerSecretEnc String
  passkeyEnc        String?
  mpesaGateway      MpesaGateway  @default(DARAJA)
  paystackSubaccount String?
  apiKeyEnc         String?
  isMain            Boolean       @default(false)
  isActive          Boolean       @default(true)
  orders            order[]
  deliveryZones     DeliveryZone[]
  adminProfiles     adminProfile[]
  transactions      transaction[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([county, isActive])
  @@schema("public")
}

model DeliveryZone {
  id             String   @id @default(uuid())
  county         String
  name           String
  branchId       String?
  branch         branch?  @relation(fields: [branchId], references: [id])
  deliveryFeeKes Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([county, isActive])
  @@index([branchId])
  @@schema("public")
}

model transaction {
  id                   String          @id @default(uuid())
  orderId              String
  order                order           @relation(fields: [orderId], references: [id])
  branchId             String?
  branch               branch?         @relation(fields: [branchId], references: [id])
  provider             PaymentProvider
  checkoutRequestId    String?         @unique
  paystackReference    String?         @unique
  amount               Int
  status               TxStatus        @default(PENDING)
  rawRequestPayload    Json?
  rawCallbackPayload   Json?
  mpesaReceiptNumber   String?
  failureReason        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([orderId])
  @@index([checkoutRequestId])
  @@index([status, createdAt])
  @@schema("public")
}

model contactMessage {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(new)
  createdAt DateTime      @default(now())

  @@index([status, createdAt])
  @@schema("public")
}

// ============================================================================
// Admin models (admin schema)
// ============================================================================

model adminProfile {
  id          String     @id @default(uuid())
  userId      String     @unique
  user        user       @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      branch?    @relation(fields: [branchId], references: [id])
  fullName        String
  permissions     Json       @default("{}")
  department      String?
  role            String     @default("viewer")
  twoFaMethod     String     @default("totp")
  isSuperAdmin    Boolean    @default(false)
  isActive        Boolean    @default(true)
  accessExpiresAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  auditLogs       auditLog[]

  @@index([branchId])
  @@schema("admin")
}

model auditLog {
  id             String       @id @default(uuid())
  adminProfileId String
  adminProfile   adminProfile @relation(fields: [adminProfileId], references: [id])
  action         String
  resource       String
  resourceId     String?
  details        Json?
  ipAddress      String?
  createdAt      DateTime     @default(now())

  @@index([adminProfileId, createdAt])
  @@schema("admin")
}

model systemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@schema("admin")
}

model notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
  @@schema("admin")
}

// ============================================================================
// Client models (client schema)
// ============================================================================

model clientProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String?
  country     String?
  city        String?
  companyId   String?  @unique
  companyName String?
  loginCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("client")
}

// ============================================================================
// Support Tickets (public schema)
// ============================================================================

model supportTicket {
  id             String          @id @default(cuid())
  ticketNumber   String          @unique
  userId         String
  user           user            @relation(fields: [userId], references: [id])
  subject        String
  status         TicketStatus    @default(OPEN)
  lastActivityAt DateTime        @default(now())
  expiresAt      DateTime
  messages       ticketMessage[]
  createdAt      DateTime        @default(now())

  @@index([status, lastActivityAt])
  @@schema("public")
}

model ticketMessage {
  id           String        @id @default(cuid())
  ticketId     String
  ticket       supportTicket @relation(fields: [ticketId], references: [id])
  senderType   MessageSender
  content      String        @db.Text
  emailSentAt  DateTime?
  createdAt    DateTime      @default(now())

  @@index([ticketId])
  @@schema("public")
}

// ============================================================================
// Loyalty (public schema)
// ============================================================================

model loyaltyPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      user     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  tier      String   @default("BRONZE")
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model couponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  userId     String
  orderId    String   @unique
  redeemedAt DateTime @default(now())

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@schema("public")
}

// ============================================================================
// Marketing (admin schema)
// ============================================================================

model campaign {
  id                   String         @id @default(cuid())
  name                 String
  type                 CampaignType
  audienceType         String         @default("ALL")
  subject              String?
  heading              String?
  previewText          String?
  content              String?        @db.Text
  audienceCustomerIds  String[]       @default([])
  status               CampaignStatus @default(DRAFT)
  scheduledAt          DateTime?
  sentAt               DateTime?
  sentCount            Int            @default(0)
  createdAt            DateTime       @default(now())

  @@schema("admin")
}

model promotion {
  id        String    @id @default(cuid())
  name      String
  type      String
  value     Float
  code      String?   @unique
  minOrder  Int?
  maxUses   Int?
  usedCount Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")
  createdAt DateTime  @default(now())

  @@schema("admin")
}

// ============================================================================
// Content (admin schema)
// ============================================================================

model blogPost {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String?
  content       String?    @db.Text
  featuredImage String?
  category      String?
  tags          String[]
  status        PostStatus @default(DRAFT)
  authorId      String
  author        user       @relation(fields: [authorId], references: [id])
  publishedAt   DateTime?
  seoTitle      String?
  metaDesc      String?
  views         Int        @default(0)
  createdAt     DateTime   @default(now())

  @@schema("admin")
}

model homepageSection {
  id      String  @id @default(cuid())
  type    String
  order   Int
  visible Boolean @default(true)
  config  Json

  @@schema("admin")
}

model banner {
  id        String    @id @default(cuid())
  name      String
  location  String
  imageKey  String
  ctaText   String?
  ctaLink   String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("active")

  @@schema("admin")
}

model faq {
  id       String @id @default(cuid())
  question String
  answer   String @db.Text
  group    String @default("General")
  order    Int    @default(0)
  status   String @default("published")

  @@schema("admin")
}

// ============================================================================
// Suppliers + Purchase Orders (admin schema)
// ============================================================================

model supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  categories     String[]
  paymentTerms   String?
  notes          String?
  status         String          @default("active")
  purchaseOrders purchaseOrder[]
  createdAt      DateTime        @default(now())

  @@schema("admin")
}

model purchaseOrder {
  id               String    @id @default(cuid())
  poNumber         String    @unique
  supplierId       String
  supplier         supplier  @relation(fields: [supplierId], references: [id])
  status           POStatus  @default(DRAFT)
  expectedDelivery DateTime?
  notes            String?
  items            Json
  totalAmount      Int
  createdAt        DateTime  @default(now())

  @@schema("admin")
}

// ============================================================================
// Loyalty Tiers (admin schema)
// ============================================================================

model loyaltyTier {
  id         String   @id @default(cuid())
  name       String
  minSpend   Int
  multiplier Float    @default(1.0)
  benefits   String[]
  color      String

  @@schema("admin")
}

// ============================================================================
// Account Dashboard models (public schema)
// ============================================================================

model orderStatusEvent {
  id         String      @id @default(cuid())
  orderId    String
  order      order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     OrderStatus
  note       String?
  occurredAt DateTime    @default(now())

  @@index([orderId])
  @@schema("public")
}

model inboxMessage {
  id        String      @id @default(cuid())
  userId    String
  user      user        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MessageType @default(SYSTEM)
  title     String
  body      String
  orderId   String?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([userId, isRead])
  @@schema("public")
}

model wishlistItem {
  id               String   @id @default(cuid())
  userId           String
  user             user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId        String
  productName      String
  productImage     String?
  priceKes         Int
  originalPriceKes Int?
  addedAt          DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@schema("public")
}
